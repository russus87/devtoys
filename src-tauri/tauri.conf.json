{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevToys",
  "version": "0.4.0",
  "identifier": "com.russus.devtoys",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "DevToys",
        "width": 1180,
        "height": 780,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "center": true
      },
      {
        "label": "quicklaunch",
        "title": "DevToys — Pannello rapido",
        "width": 540,
        "height": 470,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "msi", "dmg", "app"],
    "resources": ["pdfium/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A beautiful offline Swiss-army knife for developers",
    "longDescription": "DevToys — every little developer tool you keep googling for, in one elegant offline desktop app: JSON/YAML converters, JWT decoder, hashes, Base64, regex tester, formatters, generators and more. No data ever leaves your machine.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {}
}
